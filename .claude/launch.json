{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173
    },
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:web"],
      "port": 5173,
      "autoPort": true
    },
    {
      "name": "web-noauth",
      "runtimeExecutable": "env",
      "runtimeArgs": [
        "VITE_SUPABASE_URL=",
        "VITE_SUPABASE_ANON_KEY=",
        "npx",
        "vite"
      ],
      "port": 5173,
      "autoPort": true
    }
  ]
}
