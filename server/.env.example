# Copy to server/.env and fill in. Every value is optional — the app runs in
# local-only mode for anything left blank.
#
# The server also reads the repo-root .env.local / .env, so any key here can
# instead live alongside the frontend's VITE_SUPABASE_* keys in the root
# .env.local. Real environment variables (e.g. Render's dashboard) always win
# over both files.

# ---- AI tiers ---------------------------------------------------------------
# Two tiers; the app picks one via the in-app selector:
#   • Local ML  — always available, no key, runs entirely in the browser.
#   • Claude    — set ANTHROPIC_API_KEY below.
# Leave the key blank and the Claude tier reports "not configured" in the UI.

# ---- Claude tier ------------------------------------------------------------
ANTHROPIC_API_KEY=

# Split models (both optional — these ARE the defaults):
#   • AI_MODEL_CODE — tool suggestions + tool generation. Haiku is cheap, fast,
#     and plenty for structured JSON and React components.
#   • AI_MODEL_KNOWLEDGE — world-knowledge lookups (/api/enrich, /api/recommend,
#     with live web search). Sonnet balances knowledge depth and cost;
#     claude-opus-4-8 is deeper but ~2x the price per call.
# Setting AI_MODEL overrides BOTH (handy for testing one model everywhere).
AI_MODEL_CODE=claude-haiku-4-5
AI_MODEL_KNOWLEDGE=claude-sonnet-5
#AI_MODEL=

# Live web search on the world-knowledge routes (/api/enrich, /api/recommend).
# On by default — it's the biggest lever on knowledge quality. Set to false to
# make those calls cheaper but knowledge-only.
WEB_SEARCH=true

# Absolute ceiling on searches per AI call. Search-result tokens dominate the
# cost of a knowledge lookup, so this is the main cost lever. The prompts tell
# the model to search only for the specific fact it's missing and then stop, so
# it usually stays under this; the cap just guarantees no call runs away.
# (enrich asks for 1, recommend for up to 2; this clamps both.)
MAX_SEARCHES=2

# ---- Supabase (optional: accounts + multi-device sync) -----------------------
# To enable accounts and cross-device sync, set these Supabase credentials.
# Get them from Supabase → Settings → API.
# If blank, the app works in local-only mode (no auth, no sync).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ---- Billing (Stripe, credit model) -----------------------------------------
# The app is FULLY USABLE for free while BILLING_ENABLED is false (the default),
# so you can keep building and testing without paying. Flip it to true only when
# you want to charge.
#
# The model when enabled:
#   • £10 one-time activation unlocks the Claude tools and includes £1 of AI
#     token credit (real token value, metered per call).
#   • Once that's used, more credit is bought at £2 per £1 of tokens
#     (default top-up: £4 → £2 of credit).
BILLING_ENABLED=false

# Stripe secret key (sk_test_… / sk_live_…). No Price IDs needed — Checkout
# uses inline price_data.
STRIPE_SECRET_KEY=

# Webhook signing secret (whsec_…) from `stripe listen` or the dashboard webhook.
# Without it the server still parses events (fine for local `stripe listen`).
STRIPE_WEBHOOK_SECRET=

# Optional commercial knobs (values in pence unless noted):
# ACTIVATION_PRICE_PENCE=1000    # the flat fee (£10)
# ACTIVATION_CREDIT_PENCE=100    # token credit included with activation (£1)
# TOKEN_MARKUP=2                 # £ paid per £1 of tokens after that
# TOPUP_PRICE_PENCE=400          # default top-up purchase (£4 → £2 of tokens)
# USD_TO_GBP=0.78                # Anthropic bills USD; credit is GBP

# Comma-separated clientIds that are NEVER billed. Put your own browser's id
# here (localStorage key `evolve.clientId`) so you can keep testing a deployed
# app for free even with billing enabled for everyone else.
FREE_CLIENT_IDS=

# ---- Google Calendar --------------------------------------------------------
# Create an OAuth 2.0 Client (type: Web application) in Google Cloud Console,
# enable the Google Calendar API, and add the redirect URI below to it.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8787/auth/google/callback

# Where the browser should land after the OAuth dance (the Vite dev app).
APP_ORIGIN=http://localhost:5173

PORT=8787
