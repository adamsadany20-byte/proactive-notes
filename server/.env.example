# Copy to server/.env and fill in. Every value is optional — the app runs in
# local-only mode for anything left blank.

# ---- AI tiers ---------------------------------------------------------------
# Two tiers; the app picks one via the in-app selector:
#   • Local ML  — always available, no key, runs entirely in the browser.
#   • Claude    — set ANTHROPIC_API_KEY below (Haiku by default).
# Leave the key blank and the Claude tier reports "not configured" in the UI.

# ---- Claude tier ------------------------------------------------------------
ANTHROPIC_API_KEY=

# Model used for the Claude tier (tool suggestions, tool generation, and
# world-knowledge lookups). Defaults to claude-haiku-4-5 (fast + cheap).
AI_MODEL=claude-haiku-4-5

# ---- Billing (Stripe subscriptions) -----------------------------------------
# The app is FULLY USABLE for free while BILLING_ENABLED is false (the default),
# so you can keep building and testing without paying. Flip it to true only when
# you want to charge: then the Claude AI tools require an active subscription.
BILLING_ENABLED=false

# From the Stripe dashboard. Secret key (sk_test_… / sk_live_…) and the recurring
# Price id (price_…) for your subscription product.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=

# Webhook signing secret (whsec_…) from `stripe listen` or the dashboard webhook.
# Without it the server still parses events (fine for local `stripe listen`).
STRIPE_WEBHOOK_SECRET=

# ---- Google Calendar --------------------------------------------------------
# Create an OAuth 2.0 Client (type: Web application) in Google Cloud Console,
# enable the Google Calendar API, and add the redirect URI below to it.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8787/auth/google/callback

# Where the browser should land after the OAuth dance (the Vite dev app).
APP_ORIGIN=http://localhost:5173

PORT=8787
