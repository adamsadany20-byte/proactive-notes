# Copy to server/.env and fill in. Every value is optional — the app runs in
# local-only mode for anything left blank.

# ---- AI tiers ---------------------------------------------------------------
# Four independent tiers; the app picks one via the in-app selector:
#   • Local ML  — always available, no key, runs entirely in the browser.
#   • Gemini    — set GOOGLE_GEMINI_API_KEY below.
#   • Claude    — set ANTHROPIC_API_KEY below (Haiku by default).
#   • Groq      — set GROQ_API_KEY below (Groq Cloud).
# Leave a key blank and that tier reports "not configured" in the UI.

# ---- Claude (Haiku tier) ----------------------------------------------------
ANTHROPIC_API_KEY=

# Model used for the Claude tier (tool suggestions, tool generation, and
# world-knowledge lookups). Defaults to claude-haiku-4-5 (fast + cheap).
AI_MODEL=claude-haiku-4-5

# ---- Gemini tier ------------------------------------------------------------
# Create a key at https://aistudio.google.com/apikey (starts with "AIza...").
GOOGLE_GEMINI_API_KEY=

# Model used for the Gemini tier. Defaults to gemini-2.0-flash (fast + cheap).
GEMINI_MODEL=gemini-2.0-flash

# ---- Groq tier (Groq Cloud) -------------------------------------------------
# Create a key at https://console.groq.com/keys (starts with "gsk_...").
GROQ_API_KEY=

# Model used for the Groq tier. Defaults to llama-3.3-70b-versatile. Any model
# Groq serves works (e.g. llama-3.1-8b-instant, gemma2-9b-it).
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Google Calendar --------------------------------------------------------
# Create an OAuth 2.0 Client (type: Web application) in Google Cloud Console,
# enable the Google Calendar API, and add the redirect URI below to it.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8787/auth/google/callback

# Where the browser should land after the OAuth dance (the Vite dev app).
APP_ORIGIN=http://localhost:5173

PORT=8787
