{
  "name": "proactive-notes",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n web,api -c cyan,green \"vite\" \"npm --prefix server run dev\"",
    "dev:web": "vite",
    "dev:server": "npm --prefix server run dev",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "start": "node server/index.js",
    "postinstall": "npm --prefix server install"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sucrase": "^3.35.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
